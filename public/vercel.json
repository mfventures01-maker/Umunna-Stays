{
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/(secure-admin-login|admin-dashboard|admin-blog-cms|profile|favorites|food|transport|services|host)(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/((?!blog|stays|assets|sitemap.xml|robots.txt|site.webmanifest).*)",
            "destination": "/index.html"
        }
    ]
}
